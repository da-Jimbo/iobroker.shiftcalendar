{
  "type": "tabs",
  "items": {

    "tabGeneral": {
      "type": "tab",
      "label": "Allgemein",
      "items": {

        "preset": {
          "type": "select",
          "label": "Schichtmodell",
          "options": [
            { "label": "3-Schicht 21-Tage (NNNNN-WE-SSSSS-WE-FFFFF-WE)", "value": "3schicht_21" },
            { "label": "3-Schicht (FFSSNNXX)",                             "value": "3schicht"    },
            { "label": "2-Schicht (FFSSXX)",                               "value": "2schicht"    },
            { "label": "Kontinuierlicher Betrieb 4-Schicht (FSNX)",        "value": "4schicht"    },
            { "label": "Wechselschicht (FNXX)",                            "value": "wechsel"     },
            { "label": "Benutzerdefiniert",                                "value": "custom"      }
          ],
          "default": "3schicht_21",
          "sm": 12
        },

        "referenceDate": {
          "type": "text",
          "label": "Referenzdatum (Zyklus-Tag 1) – Format YYYY-MM-DD",
          "placeholder": "z.B. 2024-01-01",
          "help": "Das Datum, an dem dein Schichtzyklus beginnt (= erster Werktag der Nachtschicht-Woche). Leer lassen = heute.",
          "sm": 12
        }

      }
    },

    "tabCustom": {
      "type": "tab",
      "label": "Benutzerdefiniert",
      "hidden": "data.preset !== 'custom'",
      "items": {

        "hdrPattern": {
          "type": "header",
          "text": "Schichtmuster"
        },

        "customPattern": {
          "type": "text",
          "label": "Muster (Buchstabenfolge, z.B. FFSSNNXX)",
          "placeholder": "FFSSNNXX",
          "help": "Jeder Buchstabe = 1 Tag. Der Zyklus wiederholt sich endlos ab Referenzdatum.",
          "sm": 12
        },

        "hdrDefs": {
          "type": "header",
          "text": "Schichttypen"
        },

        "customShiftDefsHint": {
          "type": "staticText",
          "text": "Trage hier jeden Buchstaben aus dem Muster ein. Für Frei/Ruhetage Zeiten leer lassen.",
          "sm": 12
        },

        "customShiftDefs": {
          "type": "table",
          "label": "Schichttypen",
          "showSecondAddAt": 0,
          "items": {
            "key":   { "type": "text",  "label": "Kürzel",         "width": "70px",  "placeholder": "F" },
            "label": { "type": "text",  "label": "Bezeichnung",    "placeholder": "Frühschicht" },
            "start": { "type": "text",  "label": "Beginn (HH:MM)", "width": "110px", "placeholder": "06:00" },
            "end":   { "type": "text",  "label": "Ende (HH:MM)",   "width": "110px", "placeholder": "14:00" },
            "color": { "type": "color", "label": "Farbe",          "width": "80px"  }
          },
          "sm": 12
        }

      }
    },

    "tabVacation": {
      "type": "tab",
      "label": "Urlaub",
      "items": {

        "hdrVacation": {
          "type": "header",
          "text": "Urlaubstage (Admin-Einstellung)"
        },

        "vacationHint": {
          "type": "staticText",
          "text": "Hier kannst du Urlaubstage oder -zeiträume dauerhaft hinterlegen. Alternativ lassen sich Urlaube auch zur Laufzeit per Skript/Blockly in den Datenpunkt 'vacation.json' schreiben.",
          "sm": 12
        },

        "vacationEntries": {
          "type": "table",
          "label": "Urlaubseinträge",
          "showSecondAddAt": 0,
          "items": {
            "date": {
              "type": "text",
              "label": "Einzeltag (YYYY-MM-DD)",
              "placeholder": "2025-07-15",
              "help": "Einzelner Urlaubstag. Entweder dieses Feld ODER Von+Bis verwenden."
            },
            "from": {
              "type": "text",
              "label": "Von (YYYY-MM-DD)",
              "placeholder": "2025-08-01"
            },
            "to": {
              "type": "text",
              "label": "Bis (YYYY-MM-DD)",
              "placeholder": "2025-08-14"
            }
          },
          "sm": 12
        }

      }
    }

  }
}
