    "type": "general",
    "loglevel": "info",
    "connectionType": "local",
    "dataSource": "none",
    "adminUI": {
      "config": "json"
    },
    "keywords": ["schicht", "kalender", "schichtplan", "urlaub", "arbeitszeit", "nachtschicht"]
